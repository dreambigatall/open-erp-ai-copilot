# ── AI Providers (add whichever you have) ────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
GROK_API_KEY=xai-...

# ── Active provider for the demo app ─────────────────────
# Options: claude | openai | gemini | grok
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514
AI_FALLBACK_MODEL=claude-3-5-sonnet-latest
AI_PROMPT_VERSION=v1
AI_MAX_SCHEMA_COLLECTIONS=8

# ── Database connections ──────────────────────────────────
# Options: mongodb | postgresql (default: postgresql)
DB_TYPE=postgresql

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=erp_demo
# Use port 5433 when Postgres is started via docker-compose.yml (host maps 5433 → container 5432)
PG_CONNECTION_STRING=postgresql://postgres:password@localhost:5433/erp_demo

# ── Server ────────────────────────────────────────────────
PORT=3005

# ── Dashboard UI (Vite) ──────────────────────────────────
# Set in packages/dashboard-ui/.env or as VITE_ prefixed vars
VITE_API_BASE_URL=http://localhost:3005
