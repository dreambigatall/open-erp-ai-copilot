{
  "name": "erp-copilot",
  "private": true,
  "version": "0.0.1",
  "description": "Open-source AI copilot framework for ERP systems",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erp-copilot/erp-ai-copilot.git"
  },
  "bugs": {
    "url": "https://github.com/erp-copilot/erp-ai-copilot/issues"
  },
  "homepage": "https://github.com/erp-copilot/erp-ai-copilot#readme",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "clean:modules": "node ./scripts/clean-node-modules.mjs",
    "prepare": "husky",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "esbuild": "0.21.5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "ink-spinner": "^5.0.0"
  }
}
