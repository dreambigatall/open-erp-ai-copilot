{
  "name": "@erp-copilot/ai-core",
  "version": "0.0.1",
  "private": false,
  "description": "NL-to-query engine for ERP Copilot with pluggable LLM providers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "import": "./dist/prompts.js",
      "default": "./dist/prompts.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erp-copilot/erp-ai-copilot.git",
    "directory": "packages/ai-core"
  },
  "bugs": {
    "url": "https://github.com/erp-copilot/erp-ai-copilot/issues"
  },
  "homepage": "https://github.com/erp-copilot/erp-ai-copilot/tree/main/packages/ai-core#readme",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "node ../../scripts/rm-dist.mjs",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.40.0",
    "@google/generative-ai": "^0.11.0",
    "@erp-copilot/types": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.2"
  }
}
