{
  "name": "@erp-copilot/dashboard-ui",
  "version": "0.0.1",
  "private": false,
  "description": "React dashboard UI for ERP Copilot",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erp-copilot/erp-ai-copilot.git",
    "directory": "packages/dashboard-ui"
  },
  "bugs": {
    "url": "https://github.com/erp-copilot/erp-ai-copilot/issues"
  },
  "homepage": "https://github.com/erp-copilot/erp-ai-copilot/tree/main/packages/dashboard-ui#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose --environment jsdom",
    "clean": "node ../../scripts/rm-dist.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "recharts": "^3.8.0"
  }
}
