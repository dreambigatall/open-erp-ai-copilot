{
  "name": "@erp-copilot/connector-pg",
  "version": "0.0.1",
  "private": false,
  "description": "PostgreSQL connector for ERP Copilot (schema + read queries)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erp-copilot/erp-ai-copilot.git",
    "directory": "packages/connector-pg"
  },
  "bugs": {
    "url": "https://github.com/erp-copilot/erp-ai-copilot/issues"
  },
  "homepage": "https://github.com/erp-copilot/erp-ai-copilot/tree/main/packages/connector-pg#readme",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "node ../../scripts/rm-dist.mjs",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "@erp-copilot/types": "*"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
}
